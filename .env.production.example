# Variables d'environnement — Production Vercel
# À configurer dans : Vercel > Project Settings > Environment Variables
# Scope : Production (ne pas cocher Preview sauf besoin explicite)

# ------------------------------------------------------------------
# OBLIGATOIRE — URL de l'API backend de production
# Format recommandé : /api (si le domaine teamblender.io proxy déjà /api vers le backend)
# Alternative : https://votre-backend.railway.app/api (sans slash final)
# ------------------------------------------------------------------
# Use /api by default in production.
NEXT_PUBLIC_API_BASE=/api

# ------------------------------------------------------------------
# RECOMMANDE — origine publique backend pour les assets uploades (/uploads/*)
# Permet d'afficher correctement les images meme si NEXT_PUBLIC_API_BASE=/api
# Exemple: https://your-backend.up.railway.app
# ------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_ORIGIN=

# ------------------------------------------------------------------
# OBLIGATOIRE — origine backend cible pour les rewrites Next.js (server-side)
# Doit pointer vers l'origine Railway active (sans slash final).
# Exemples valides :
# BACKEND_ORIGIN=https://your-backend.up.railway.app
# BACKEND_ORIGIN=https://your-backend.up.railway.app/api
# ------------------------------------------------------------------
BACKEND_ORIGIN=

# ------------------------------------------------------------------
# Optionnel — URL du frontend legacy (utilisé uniquement par local_page_v1)
# Peut pointer vers l'ancienne URL pendant la période de transition
# ------------------------------------------------------------------
NEXT_PUBLIC_LEGACY_BASE=https://VOTRE_LEGACY_URL

# ------------------------------------------------------------------
# Optionnel — Google Analytics 4 (ex: G-XXXXXXXXXX)
# Active le tracking pageview si defini.
# ------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ------------------------------------------------------------------
# NE PAS CONFIGURER EN PRODUCTION (smoke tests = CI uniquement)
# ------------------------------------------------------------------
# SMOKE_FRONTEND_URL=
# SMOKE_BACKEND_URL=
# SMOKE_MANAGER_EMAIL=
# SMOKE_MANAGER_PASSWORD=
# SMOKE_PARTICIPANT_PASSWORD=
# SMOKE_CHALLENGE_ENGINE=
# SMOKE_BROWSER_CHANNEL=
