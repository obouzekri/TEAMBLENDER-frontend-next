{
  "name": "teamblender-frontend-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --ignore-path ../.prettierignore",
    "format:check": "prettier . --check --ignore-path ../.prettierignore",
    "test:smoke": "npm run test:smoke:manager && npm run test:smoke:participant",
    "test:smoke:manager": "node scripts/smoke.mjs",
    "test:smoke:participant": "node scripts/smoke-participant.mjs",
    "test:smoke:session-builder": "node scripts/smoke-session-builder-catalog.mjs",
    "test:smoke:login": "node scripts/smoke-login-redirect.mjs",
    "test:smoke:preview": "npm run test:smoke:login && npm run test:smoke:session-builder",
    "test:unit:vom": "node scripts/test-vom-utils.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "postcss": "8.5.14",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "socket.io-client": "^4.7.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0"
  }
}
