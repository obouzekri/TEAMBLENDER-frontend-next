{
  "name": "teamblender-frontend-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build --webpack",
    "start": "next start -p 3100",
    "lint": "eslint .",
    "lint:i18n": "node scripts/check-i18n.mjs",
    "check:i18n": "npm run lint:i18n",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write --ignore-path ../.prettierignore",
    "format:check": "prettier . --check --ignore-path ../.prettierignore",
    "test:smoke": "npm run test:smoke:manager && npm run test:smoke:participant",
    "test:smoke:manager": "node scripts/smoke.mjs",
    "test:smoke:participant": "node scripts/smoke-participant.mjs",
    "test:smoke:session-builder": "node scripts/smoke-session-builder-catalog.mjs",
    "test:smoke:login": "node scripts/smoke-login-redirect.mjs",
    "test:smoke:preview": "npm run test:smoke:login && npm run test:smoke:session-builder",
    "test:unit:vom": "node scripts/test-vom-utils.mjs",
    "test:unit:auth": "node scripts/test-auth.mjs",
    "test:unit:builder": "node scripts/test-session-builder-utils.mjs",
    "test:unit:runtime": "node scripts/test-runtime-dispatcher.mjs",
    "test:unit": "npm run test:unit:vom && npm run test:unit:auth && npm run test:unit:builder && npm run test:unit:runtime",
    "test:integration:manager-participant": "node scripts/test-integration-manager-participant.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "postcss": "8.5.14",
    "posthog-js": "^1.379.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "socket.io-client": "^4.7.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "19.2.17",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
